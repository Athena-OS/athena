pkgname=athena-welcome
pkgver=49.80fc198
pkgrel=2
pkgdesc='Welcome App for Athena.'
arch=('any')
license=('GPL-3.0-or-later')
depends=('athena-settings' 'cyber-toolkit' 'htb-toolkit' 'rate-mirrors' 'rsync')
makedepends=('git')
source=("git+https://github.com/Athena-OS/$pkgname.git")
sha512sums=('SKIP')

pkgver() {
  cd $pkgname

  ( set -o pipefail
    git describe --long --tags --abbrev=7 2>/dev/null |
      sed 's/\([^-]*-g\)/r\1/;s/-/./g' ||
    printf "%s.%s" "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=7 HEAD)"
  )
}

package() {
  cd $pkgname

  install -dm 755 "$pkgdir/usr/bin"

  install -Dm 644 athena-welcome.desktop "$pkgdir/etc/skel/.config/autostart/athena-welcome.desktop"
  install -Dm 644 athena-welcome.desktop "$pkgdir/usr/share/applications/athena-welcome.desktop"
  install -Dm 644 athenaos.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/athenaos.svg"
  cp -a "athena-welcome" "$pkgdir/usr/share/"

  cat > "$pkgdir/usr/bin/$pkgname" << EOF
#!/usr/bin/env bash
cd /usr/share/athena-welcome
sleep 3
exec python athena-welcome.py "\$@"
EOF

  chmod +x "$pkgdir/usr/bin/$pkgname"
}

