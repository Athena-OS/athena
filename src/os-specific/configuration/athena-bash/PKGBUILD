package() {
  install -dm 755 "${pkgdir}/etc/skel"

  install -Dm 644 .bash_aliases "${pkgdir}/etc/skel/.bash_aliases"
  install -Dm 644 .blerc "${pkgdir}/etc/skel/.blerc"
}
